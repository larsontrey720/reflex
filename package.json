{
  "name": "reflex-quality",
  "version": "1.0.0",
  "description": "Your code's reflex. Self-enhancing code quality system that diagnoses, prescribes, and fixes autonomously.",
  "type": "module",
  "bin": {
    "reflex": "./cli/index.ts"
  },
  "main": "./cli/index.ts",
  "files": [
    "cli/",
    "skills/",
    "reflex.config.ts",
    "reflex-logo.svg",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "preinstall": "bun --version || echo 'Bun required: install from bun.sh'",
    "introspect": "bun run skills/reflex-introspect/scripts/introspect.ts",
    "prescribe": "bun run skills/reflex-prescribe/scripts/prescribe.ts",
    "evolve": "bun run skills/reflex-evolve/scripts/evolve.ts",
    "interview": "bun run skills/reflex-interview/scripts/interview.ts",
    "eval": "bun run skills/reflex-eval/scripts/evaluate.ts",
    "unstuck": "bun run skills/reflex-unstuck/scripts/unstuck.ts",
    "loop": "bun run skills/reflex-loop/scripts/autofix.ts",
    "full-cycle": "bun run cli/full-cycle.ts",
    "check": "bun run cli/index.ts check",
    "fix": "bun run cli/index.ts fix",
    "security": "bun run cli/index.ts security",
    "plan": "bun run cli/index.ts plan",
    "test": "bun test"
  },
  "keywords": [
    "reflex",
    "code-quality",
    "static-analysis",
    "self-improving",
    "autonomous",
    "developer-tools",
    "ai",
    "llm",
    "refactoring",
    "testing",
    "typescript",
    "cli",
    "code-analysis",
    "bug-detection",
    "security-scanner"
  ],
  "author": "larsontrey720",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/larsontrey720/reflex.git"
  },
  "homepage": "https://github.com/larsontrey720/reflex#readme",
  "bugs": {
    "url": "https://github.com/larsontrey720/reflex/issues"
  },
  "dependencies": {
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.0.0"
}
